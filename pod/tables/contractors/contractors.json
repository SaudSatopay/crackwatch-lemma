{
  "name": "contractors",
  "primary_key_column": "id",
  "enable_rls": false,
  "visibility": "POD",
  "columns": [
    { "name": "name", "type": "TEXT", "required": true, "max_length": 160 },
    { "name": "sector", "type": "TEXT", "max_length": 80, "description": "Jurisdiction this contractor covers" },
    { "name": "contact", "type": "TEXT", "max_length": 160 },
    { "name": "assigned_count", "type": "INTEGER", "default": 0 },
    { "name": "resolved_count", "type": "INTEGER", "default": 0 },
    { "name": "overdue_count", "type": "INTEGER", "default": 0 },
    { "name": "avg_fix_days", "type": "FLOAT" },
    { "name": "negligence_score", "type": "FLOAT", "default": 0, "description": "Wall-of-shame metric; higher = worse" },
    { "name": "status", "type": "ENUM", "default": "active", "options": ["active", "flagged"] }
  ],
  "config": {}
}
